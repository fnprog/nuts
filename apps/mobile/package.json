{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo start --android --offline",
    "ios": "expo start --ios --offline",
    "start": "expo start --offline",
    "start:online": "expo start --offline",
    "prebuild": "expo prebuild",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web --offline",
    "check-all": "pnpm type-check && pnpm lint"
  },
  "dependencies": {
    "@nuts/constants": "workspace:*",
